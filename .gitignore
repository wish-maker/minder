# ============================================================================
# Minder Platform - Professional .gitignore
# ============================================================================

# ============================================================================
# 🔒 CRITICAL SECURITY (Never Commit)
# ============================================================================

# Environment Files
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.marketplace

# SSL Certificates & Keys
*.key
*.pem
*.crt
*.cer
secrets/
credentials/
*.credentials

# Database Files
*.db
*.sqlite
*.sqlite3
*.backup
*_backup

# Database Storage Directories
**/data/
**/data/**/*

# ============================================================================
# 🟢 AUTO-GENERATED FILES (Build & Cache)
# ============================================================================

# Python
__pycache__/
__pycache__/**/*
*.py[cod]
*.pyc
*.pyo
*.pyd
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
*.dist-info
.installed.cfg
*.egg
venv/
env/
ENV/
virtualenv/
.venv/
htmlcov/
.tox/
.coverage
*.cover
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/
.pytest_cache/
.pytest_cache/**/*

# Build & Setup Cache
.buildcache/
.buildcache/**/*
.setup/
.setup/**/*

# Node.js
node_modules/
.next/
out/
build/
.swc/

# ============================================================================
# 🤖 AI SYSTEM FILES (Personal Settings)
# ============================================================================

.claude/
.claude/**/*
.claude/settings.local.json

.serena/
.serena/**/*
.serena/project.local.yml

.remember/
.remember/**/*
.remember/logs/
.remember/tmp/

# ============================================================================
# 📝 LOGS & TEMPORARY FILES
# ============================================================================

*.log
*.tmp
*.old
*.save
*.pid
*.seed
*.pid.lock
*.lock
*.state
*.socket
*.sock
tmp/
temp/
logs/
logs/**/*

# ============================================================================
# 🖥️ IDE & EDITOR SETTINGS
# ============================================================================

.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project

# ============================================================================
# 📚 DOCUMENTATION BUILD
# ============================================================================

docs/_build/
docs/.doctrees/
site/

# ============================================================================
# 🗂️ ARCHIVE & OLD FILES
# ============================================================================

.archive/
*.archive
*.orig
*~
*.bak
*.old
*.save
*.tmp
*.temp
*.swp
*.swo
*.retry
*.failed

# ============================================================================
# 🐧 OS-SPECIFIC FILES
# ============================================================================

.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# ============================================================================
# 🎯 PROJECT SPECIFIC
# ============================================================================

# Docker Compose Test/Temp Files
docker-compose.*.test.yml
docker-compose.*.secrets.yml
*-secrets.yml
*-test.yml
correct-volumes.yml
volumes-section.yml

# System Backups (contains database dumps & credentials)
backups/
backups/**/*
*.backup
*.sql
*.dump

# Configuration Backups
*.backup.*
*.backup-*
.env.backup*
.env.backup-*
docker-compose.yml.backup*
docker-compose.yml.broken*
docker-compose.yml.old

# Environment Configuration (contains secrets)
infrastructure/docker/.env
infrastructure/docker/.env.local
infrastructure/**/.env

# Monitoring Data
grafana/data/
prometheus/data/
influxdb/data/
alertmanager/data/
monitoring-log.txt

# Docker volumes (don't commit data)
*.volume
.volumes/

# Test Results
test-results/
test-reports/
*.test.log

# AI Agent Working Directories
docs/superpowers/
docs/superpowers/**/*

# Historical Analysis Reports (development artifacts)
docs/archive/reports/
docs/archive/reports/**/*

# Development & Test Scripts
test-phase4-*.sh
validate-fresh-install.sh
generate-compose.sh
system_prompt.txt
monitoring-log.txt

# ============================================================================
# ✅ TEAM COLLABORATION (Keep These!)
# ============================================================================
# .github/          → CI/CD workflows
# *.example         → Template files
# docs/             → Documentation
# infrastructure/    → Docker configuration
# tests/            → Test suite
# services/         → Source code
