# ============================================================================
# Minder Platform - Professional .gitignore
# ============================================================================

# ============================================================================
# 🔒 CRITICAL SECURITY (Never Commit)
# ============================================================================

# Environment Files
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.marketplace

# SSL Certificates & Keys
*.key
*.pem
*.crt
*.cer
secrets/
credentials/
*.credentials

# Database Files
*.db
*.sqlite
*.sqlite3
*.backup
*_backup

# ============================================================================
# 🟢 AUTO-GENERATED FILES (Build & Cache)
# ============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.installed.cfg
*.egg
venv/
env/
ENV/
htmlcov/
.tox/
.coverage
*.cover
.pytest_cache/
.mypy_cache/
.ruff_cache/
.cache/

# Node.js
node_modules/
.next/
out/
build/
.swc/

# ============================================================================
# 🤖 AI SYSTEM FILES (Personal Settings)
# ============================================================================

.claude/
.claude/**/*
.claude/settings.local.json

.serena/
.serena/**/*
.serena/project.local.yml

.remember/
.remember/**/*
.remember/logs/
.remember/tmp/

# ============================================================================
# 📝 LOGS & TEMPORARY FILES
# ============================================================================

*.log
*.tmp
*.old
*.save
*.pid
*.seed
*.pid.lock
tmp/
temp/

# ============================================================================
# 🖥️ IDE & EDITOR SETTINGS
# ============================================================================

.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project

# ============================================================================
# 📚 DOCUMENTATION BUILD
# ============================================================================

docs/_build/
docs/.doctrees/
site/

# ============================================================================
# 🗂️ ARCHIVE & OLD FILES
# ============================================================================

.archive/
*.archive
*.orig
*~

# ============================================================================
# 🐧 OS-SPECIFIC FILES
# ============================================================================

.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# ============================================================================
# 🎯 PROJECT SPECIFIC
# ============================================================================

# Monitoring Data
grafana/data/
prometheus/data/
influxdb/data/
alertmanager/data/

# Docker volumes (don't commit data)
*.volume
.volumes/

# Test Results
test-results/
test-reports/
*.test.log

# AI Agent Working Directories
docs/superpowers/
docs/superpowers/**/*

# ============================================================================
# ✅ TEAM COLLABORATION (Keep These!)
# ============================================================================
# .github/          → CI/CD workflows
# *.example         → Template files
# docs/             → Documentation
# infrastructure/    → Docker configuration
# tests/            → Test suite
# services/         → Source code
