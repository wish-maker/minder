# ============================================================================
# 🎯 PROJECT SPECIFIC
# ============================================================================

# Docker Compose Test/Temp Files
docker-compose.*.test.yml
docker-compose.*.secrets.yml
*-secrets.yml
*-test.yml
correct-volumes.yml
volumes-section.yml

# System Backups (contains database dumps & credentials)
backups/
backups/**/*
*.backup
*.sql
*.dump
# Exception: track the Postgres init script (infrastructure, not a dump). It is mounted
# into postgres and creates all required databases on a clean install (apicurio fix).
# This is the ONLY live infra SQL — keep it tracked.
#
# AUDIT (2026-06-28): the 7 other *.sql files this rule hid were checked individually
# and found NOT clean-install-critical (the rule was not hiding live infra after all):
#   - postgres migrations 001/002/003 (event_store/projections/idempotency): not mounted,
#     not \i-included by init.sql, no Alembic versions, tables unused → DELETED as orphans.
#   - rag-pipeline migrations/001_initial_schema.sql: initialize_schema() is called with no
#     file arg → inline default schema is used; file never read → DELETED.
#   - marketplace plugin_tables.sql / schema_complete.sql: zero references → DELETED.
#   - marketplace migrations/schema.sql: was a BYTE-IDENTICAL dup of the tracked
#     ../schema.sql → DELETED (#10, 2026-07-04). run_migrations() now reads only the
#     tracked src/services/marketplace/schema.sql (single source of truth).
# So no further !-exceptions are needed; the blanket *.sql rule correctly ignores dumps.
!docker/services/postgres/init.sql

# Runtime telegraf.conf: seeded from the tracked template (telegraf.conf) by
# setup.sh; the telegraf plugin writes its managed region here, so this copy must
# stay untracked or every `start` would dirty the repo. Template stays tracked.
docker/services/telegraf/telegraf.runtime.conf

# Gate harness — generated traces are regenerated on demand; the harness is the
# durable artifact (a committed golden trace would go stale + is machine-sensitive).
scripts/gate/*.trace

# Configuration Backups
*.backup.*
*.backup-*
.env.backup*
.env.backup-*
docker-compose.yml.backup*
docker-compose.yml.broken*
docker-compose.yml.old

# Environment Configuration (contains secrets)
docker/compose/.env
docker/compose/.env.local
docker/**/.env

# Monitoring Data
grafana/data/
prometheus/data/
influxdb/data/
alertmanager/data/
monitoring-log.txt

# Docker volumes (don't commit data)
*.volume
.volumes/

# Test Results
test-results/
test-reports/
*.test.log
test_output.txt
test_version_logic.py
test_auth_demo.py
test_auth_e2e_simple.py
test_jwt_validation.sh
test_model_management.sh

# Self-test scratch files (repo root only — must NOT hide real tests under tests/)
/test_*.py
/test_*.json

# AI Agent Working Directories (if needed in future)
# docs/superpowers/
# docs/superpowers/**/*

# Development & Test Scripts (if needed in future)
# test-phase4-*.sh
# validate-fresh-install.sh
# generate-compose.sh
# system_prompt.txt
# monitoring-log.txt

# ============================================================================
# ✅ TEAM COLLABORATION (Keep These!)
# ============================================================================
# .github/          → CI/CD workflows
# *.example         → Template files
# docs/             → Documentation
# docker/           → Docker configuration
# src/              → Source code
# tests/            → Test suite
# scripts/          → Setup and utility scripts
