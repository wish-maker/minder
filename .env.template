# Minder Environment Configuration Template
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ===========================================
# SECURITY - REQUIRED
# ===========================================
JWT_SECRET_KEY=generate-strong-random-key-here
POSTGRES_PASSWORD=your-strong-password-here
INFLUXDB_PASSWORD=your-strong-password-here

# ===========================================
# NETWORK CONFIGURATION
# ===========================================
LOCAL_NETWORK_ENABLED=true
LOCAL_NETWORK_CIDR=192.168.1.0/24
TAILSCALE_ENABLED=true
TAILSCALE_CIDR=100.64.0.0/10
TS_AUTHKEY=tskey-auth-xxxxx

# Security Settings
TRUST_LOCAL_NETWORK=true  # No auth required for local
TRUST_VPN_NETWORK=true     # No auth required for VPN

# CORS Origins (comma-separated)
ALLOWED_ORIGINS_LOCAL=http://localhost:3000,http://192.168.1.*
ALLOWED_ORIGINS_VPN=http://100.*.*.*,https://*.tailscale.net

# ===========================================
# DATABASE CONNECTIONS
# ===========================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=fundmind
POSTGRES_USER=postgres

INFLUXDB_HOST=influxdb
INFLUXDB_PORT=8086
INFLUXDB_TOKEN=your-influxdb-token
INFLUXDB_ORG=minder
INFLUXDB_BUCKET=metrics

QDRANT_HOST=qdrant
QDRANT_PORT=6333

REDIS_HOST=redis
REDIS_PORT=6379

# ===========================================
# APPLICATION SETTINGS
# ===========================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# JWT Settings
JWT_EXPIRE_MINUTES=30

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_HOUR=200

# Plugin Store
PLUGIN_STORE_ENABLED=true
PLUGIN_STORE_PATH=/var/lib/minder/plugins
PLUGIN_REQUIRE_SIGNATURE=true
PLUGIN_SCAN_MALWARE=true

# ===========================================
# VOICE INTERFACE
# ===========================================
VOICE_ENABLED=true
STT_MODEL=whisper-medium
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
DEFAULT_LANGUAGE=tr

# ===========================================
# CHARACTER SYSTEM
# ===========================================
CHARACTER_DEFAULT=finbot
CUSTOM_CHARACTERS_PATH=/var/lib/minder/characters

# ===========================================
# PERFORMANCE
# ===========================================
MAX_WORKERS=4
BATCH_SIZE=100
CACHE_TTL=3600