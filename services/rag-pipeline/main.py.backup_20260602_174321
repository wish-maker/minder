class HybridSearchRetriever:
    """Hybrid search combining semantic (dense) and BM25 (sparse) retrieval"""

    def __init__(self, alpha: float = 0.5):
        self.alpha = alpha
        self.sparse_index: Dict[str, Any] = {}
        self.documents: Dict[str, List[Dict]] = {}

    def index_documents(self, kb_id: str, documents: List[Dict]):
        """Build BM25 index for documents (RPi 4 optimized)"""
        import re
        from rank_bm25 import BM25Okapi

        # Tokenize and build BM25 index
        corpus = []
        for doc in documents:
            text = doc.get("text", "")
            tokens = re.findall(r"\w+", text.lower())
            corpus.append(tokens)

        if corpus:
            self.sparse_index[kb_id] = BM25Okapi(corpus)
            self.documents[kb_id] = documents
            logger.info(f"✅ BM25 index built for KB {kb_id}: {len(documents)} docs")

    async def hybrid_search(
        self, kb_id: str, query_embedding: List[float], query: str, dense_results: List, top_k: int = 5
    ) -> List[Tuple[Any, float]]:
        """Perform hybrid search combining dense and sparse scores"""
        import re
        import numpy as np

        # Retrieve from both methods
        dense_scores = {r.payload.get("_id", r.id): r.score for r in dense_results[: top_k * 2]}
        sparse_results = self._sparse_search(kb_id, query, top_k * 2)

        # Normalize and combine scores
        hybrid_scores = {}
        for doc_id, score in dense_scores.items():
            hybrid_scores[doc_id] = self.alpha * self._normalize_score(score, dense_scores)

        for doc_id, score in sparse_results.items():
            if doc_id in hybrid_scores:
                hybrid_scores[doc_id] += (1 - self.alpha) * self._normalize_score(score, sparse_results)
            else:
                hybrid_scores[doc_id] = (1 - self.alpha) * self._normalize_score(score, sparse_results)

        # Return top-k results
        sorted_results = sorted(hybrid_scores.items(), key=lambda x: x[1], reverse=True)
        return [(doc_id, score) for doc_id, score in sorted_results[:top_k]]

    def _sparse_search(self, kb_id: str, query: str, k: int) -> Dict[str, float]:
        """Perform sparse search using BM25"""
        import re
        import numpy as np

        if kb_id not in self.sparse_index:
            return {}

        query_tokens = re.findall(r"\w+", query.lower())
        scores = self.sparse_index[kb_id].get_scores(query_tokens)

        # Map to document IDs
        top_indices = np.argsort(scores)[::-1][:k]

        doc_ids = []
        documents = self.documents.get(kb_id, [])
        for idx in top_indices:
            if idx < len(documents):
                doc_id = documents[idx].get("_id", f"doc_{idx}")
                doc_ids.append((doc_id, float(scores[idx])))

        return dict(doc_ids)

    def _normalize_score(self, score: float, scores: Dict[str, float]) -> float:
        """Normalize score to [0,1] range"""
        if not scores:
            return 0.0

        max_score = max(scores.values()) if scores else 1.0
        if max_score == 0:
            return 0.0

        return score / max_score


# Global hybrid searcher
hybrid_searcher = HybridSearchRetriever(alpha=0.5)


