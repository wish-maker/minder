class ContextualCompressor:
    """Compress retrieved context while preserving relevance (RPi 4 optimized)"""

    def __init__(self, max_tokens: int = 2000, compression_ratio: float = 0.3):
        self.max_tokens = max_tokens
        self.compression_ratio = compression_ratio
        self.avg_chars_per_token = 4

    def compress(self, query: str, contexts: List[Dict]) -> Dict[str, Any]:
        """Compress context while preserving relevance"""
        if not contexts:
            return {"compressed_context": "", "original_length": 0}

        original_text = "\n\n".join([ctx.get("text", "") for ctx in contexts])
        target_length = int(len(original_text) * self.compression_ratio)

        # Extract key sentences based on query relevance
        compressed = self._extract_key_sentences(query, original_text, target_length)

        # Ensure we don't exceed max tokens
        max_chars = self.max_tokens * self.avg_chars_per_token
        if len(compressed) > max_chars:
            compressed = compressed[:max_chars] + "..."

        return {
            "compressed_context": compressed,
            "original_length": len(original_text),
            "compressed_length": len(compressed),
        }

    def _extract_key_sentences(self, query: str, text: str, target_length: int) -> str:
        """Extract key sentences based on query relevance"""
        sentences = [s.strip() for s in text.split(".") if s.strip()]

        if not sentences:
            return text[:target_length]

        # Score sentences by query relevance
        query_words = set(query.lower().split())
        sentence_scores = []

        for sentence in sentences:
            sentence_lower = sentence.lower()
            sentence_words = set(sentence_lower.split())

            overlap = len(query_words & sentence_words)
            score = overlap / max(len(query_words), 1)
            sentence_scores.append((sentence, score))

        # Sort by relevance
        sorted_sentences = sorted(sentence_scores, key=lambda x: x[1], reverse=True)

        # Take top sentences until target length
        compressed_sentences = []
        current_length = 0

        for sentence, score in sorted_sentences:
            if current_length + len(sentence) <= target_length:
                compressed_sentences.append(sentence)
                current_length += len(sentence) + 2
            else:
                break

        return ". ".join(compressed_sentences) + "." if compressed_sentences else ""


# Global compressor
context_compressor = ContextualCompressor(max_tokens=2000, compression_ratio=0.3)


