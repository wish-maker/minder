class ParentChildChunker:
    """Hierarchical chunking with parent-child relationships (RPi 4 optimized)"""

    def __init__(self, parent_size: int = 2000, child_size: int = 512, overlap: int = 50):
        self.parent_size = parent_size
        self.child_size = child_size
        self.overlap = overlap

    def create_hierarchy(self, text: str) -> List[Dict[str, Any]]:
        """Create parent-child chunk hierarchy"""
        # First create parent chunks
        parent_chunks = self._chunk_text(text, self.parent_size, self.overlap)

        hierarchy = []
        for parent_idx, parent_chunk in enumerate(parent_chunks):
            # Create child chunks within each parent
            child_chunks = self._chunk_text(parent_chunk, self.child_size, self.overlap)

            parent_entry = {"id": f"parent_{parent_idx}", "text": parent_chunk, "type": "parent", "children": []}

            for child_idx, child_chunk in enumerate(child_chunks):
                child_entry = {
                    "id": f"child_{parent_idx}_{child_idx}",
                    "text": child_chunk,
                    "type": "child",
                    "parent_id": f"parent_{parent_idx}",
                }
                parent_entry["children"].append(child_entry["id"])
                hierarchy.append(child_entry)

            hierarchy.append(parent_entry)

        logger.info(f"✅ Created hierarchy: {len(parent_chunks)} parents, {len(hierarchy) - len(parent_chunks)} children")
        return hierarchy

    def _chunk_text(self, text: str, chunk_size: int, overlap: int) -> List[str]:
        """Chunk text into smaller pieces"""
        from langchain_text_splitters import RecursiveCharacterTextSplitter

        text_splitter = RecursiveCharacterTextSplitter(
            chunk_size=chunk_size, chunk_overlap=overlap, length_function=len, separators=["\n\n", "\n", ". ", " ", ""]
        )

        return text_splitter.split_text(text)


class ParentChildRetriever:
    """Retriever that uses child chunks for search but returns parent context"""

    def __init__(self):
        self.hierarchies: Dict[str, List[Dict]] = {}  # kb_id -> hierarchy
        self.child_index: Dict[str, List[Dict]] = {}  # kb_id -> child chunks for search

    def index_hierarchy(self, kb_id: str, hierarchy: List[Dict]):
        """Index parent-child hierarchy for knowledge base"""
        self.hierarchies[kb_id] = hierarchy
        self.child_index[kb_id] = [item for item in hierarchy if item["type"] == "child"]
        logger.info(f"✅ Indexed hierarchy for KB {kb_id}: {len(self.child_index[kb_id])} children")

    def retrieve_with_parent_context(self, kb_id: str, child_results: List[Dict]) -> List[Dict]:
        """Retrieve child results but expand with parent context"""
        if kb_id not in self.hierarchies:
            logger.warning(f"⚠️ No hierarchy found for KB {kb_id}")
            return child_results

        enhanced_results = []
        parent_ids_seen = set()

        for child_result in child_results:
            child_id = child_result.get("id", "")
            if not child_id:
                enhanced_results.append(child_result)
                continue

            # Find parent for this child
            parent_entry = None
            if kb_id in self.hierarchies:
                for item in self.hierarchies[kb_id]:
                    if item["type"] == "parent" and child_id in item.get("children", []):
                        parent_entry = item
                        break

            if parent_entry and parent_entry["id"] not in parent_ids_seen:
                # Return parent context for first child from each parent
                enhanced_results.append({"text": parent_entry["text"], "source": child_result.get("source", ""), "score": child_result.get("score", 0.0), "context_type": "parent"})
                parent_ids_seen.add(parent_entry["id"])
            else:
                # Return child result as-is
                enhanced_results.append(child_result)

        logger.info(f"✅ Enhanced {len(child_results)} results with parent context")
        return enhanced_results


