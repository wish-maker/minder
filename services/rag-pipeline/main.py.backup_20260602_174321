class ConversationMemory:
    """Conversation memory for user context tracking and history (RPi 4 optimized)"""

    def __init__(self):
        """Initialize Redis connection for conversation storage"""
        self.redis_client = None
        self.ttl = 86400  # 24 hours default TTL
        self.max_history_length = 10  # Max 10 turns per conversation

    def initialize(self):
        """Initialize Redis connection (sync for RPi 4 stability)"""
        if not REDIS_AVAILABLE:
            logger.warning("⚠️ Redis not available, conversation memory disabled")
            return

        try:
            redis_host = os.getenv("REDIS_HOST", "redis")
            redis_port = int(os.getenv("REDIS_PORT", "6379"))
            redis_db = int(os.getenv("REDIS_DB", "0"))
            redis_password = os.getenv("REDIS_PASSWORD", "")

            self.redis_client = redis.Redis(
                host=redis_host, port=redis_port, db=redis_db, password=redis_password, decode_responses=True
            )
            self.redis_client.ping()
            logger.info("✅ Conversation memory: Redis connected")
        except Exception as e:
            logger.warning(f"⚠️ Failed to connect to Redis: {e}")
            self.redis_client = None

    def store_conversation_turn(
        self, user_id: str, conversation_id: str, question: str, answer: str, metadata: Dict = None
    ) -> bool:
        """Store a conversation turn in Redis"""
        if not self.redis_client:
            return False

        try:
            timestamp = datetime.utcnow().isoformat()

            # Store turn with metadata
            turn_key = f"conversation:{user_id}:{conversation_id}:turns"
            turn_data = {
                "question": question,
                "answer": answer,
                "timestamp": timestamp,
                "metadata": metadata or {},
            }

            # Add to list (maintain order)
            self.redis_client.lpush(turn_key, json.dumps(turn_data))

            # Trim to max history length
            self.redis_client.ltrim(turn_key, 0, self.max_history_length - 1)

            # Set TTL
            self.redis_client.expire(turn_key, self.ttl)

            logger.debug(f"💾 Stored conversation turn for {user_id}:{conversation_id}")
            return True
        except Exception as e:
            logger.warning(f"⚠️ Failed to store conversation turn: {e}")
            return False

    def retrieve_conversation_history(
        self, user_id: str, conversation_id: str, max_turns: int = 5
    ) -> List[Dict]:
        """Retrieve conversation history from Redis"""
        if not self.redis_client:
            return []

        try:
            turn_key = f"conversation:{user_id}:{conversation_id}:turns"

            # Get recent turns
            turns_data = self.redis_client.lrange(turn_key, 0, max_turns - 1)

            # Parse and reverse (oldest first)
            turns = []
            for turn_data in reversed(turns_data):
                try:
                    turn = json.loads(turn_data)
                    turns.append(turn)
                except Exception as e:
                    logger.warning(f"⚠️ Failed to parse turn data: {e}")

            logger.debug(f"📖 Retrieved {len(turns)} conversation turns for {user_id}:{conversation_id}")
            return turns
        except Exception as e:
            logger.warning(f"⚠️ Failed to retrieve conversation history: {e}")
            return []

    def get_conversation_context(
        self, user_id: str, conversation_id: str, current_question: str, max_turns: int = 3
    ) -> str:
        """Build conversational context string from history"""
        turns = self.retrieve_conversation_history(user_id, conversation_id, max_turns)

        if not turns:
            return ""

        # Build context string
        context_parts = []
        for turn in turns[-max_turns:]:
            context_parts.append(f"Q: {turn['question']}")
            context_parts.append(f"A: {turn['answer']}")

        context_str = "\n".join(context_parts)
        logger.debug(f"🔄 Built conversation context ({len(turns)} turns)")

        return context_str

    def clear_conversation(self, user_id: str, conversation_id: str) -> bool:
        """Clear conversation history"""
        if not self.redis_client:
            return False

        try:
            turn_key = f"conversation:{user_id}:{conversation_id}:turns"
            self.redis_client.delete(turn_key)
            logger.info(f"🗑️ Cleared conversation for {user_id}:{conversation_id}")
            return True
        except Exception as e:
            logger.warning(f"⚠️ Failed to clear conversation: {e}")
            return False


