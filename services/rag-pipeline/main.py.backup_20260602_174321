class Pi4ResourceManager:
    """Raspberry Pi 4 resource manager for RAG pipeline"""

    def __init__(self):
        self.max_concurrent_requests = 2  # RPi 4 constraint
        self.max_memory_mb = 4000  # 4GB for RAG pipeline
        self.cpu_threshold = 80  # Thermal throttle threshold
        self.request_semaphore = asyncio.Semaphore(self.max_concurrent_requests)
        self.embedding_batch_size = 5  # Reduced from 100

    async def check_resources(self) -> Dict[str, Any]:
        """Check available resources before processing"""
        try:
            # Read memory info
            with open("/proc/meminfo", "r") as f:
                meminfo = f.read()
                available = int([line for line in meminfo.split("\n") if "MemAvailable" in line][0].split()[1]) // 1024  # MB

            # Read CPU load
            with open("/proc/loadavg", "r") as f:
                load = float(f.read().split()[0])  # 1-minute load

            # Check thermal
            try:
                with open("/sys/class/thermal/thermal_zone0/temp", "r") as f:
                    temp = int(f.read().strip()) / 1000  # Convert to Celsius
            except:
                temp = 0  # Thermal read failed

            return {
                "available_memory_mb": available,
                "cpu_load": load,
                "temperature_c": temp,
                "can_process": available > 1000 and load < 10.0 and temp < self.cpu_threshold,  # Temporarily raised for testing
            }
        except Exception as e:
            logger.warning(f"Resource check failed: {e}")
            return {"can_process": True}  # Optimistic default

    async def throttle_if_needed(self):
        """Throttle if resources constrained"""
        while True:
            resources = await self.check_resources()
            if not resources["can_process"]:
                wait_time = min(5, resources.get("temperature_c", 0) / 20)
                logger.warning(f"⏳ Throttling: {resources}")
                await asyncio.sleep(wait_time)
            else:
                break


