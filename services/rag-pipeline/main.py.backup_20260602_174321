async def retrieve_relevant_documents(pipeline: Dict, question: str, top_k: int) -> Dict:
    """Retrieve relevant documents from knowledge bases with resource management"""
    # Throttle if resources constrained
    await pi4_manager.throttle_if_needed()

    # Use semaphore to limit concurrent requests
    async with pi4_manager.request_semaphore:
        client = get_qdrant_client()

        # Get embedding model from first KB
        first_kb_id = pipeline["knowledge_base_ids"][0]
        embed_model = knowledge_bases[first_kb_id]["embedding_model"]

        # Create embedding for question (with cache)
        question_embeddings = await ollama_manager.generate_embeddings([question], model=embed_model)
        question_embedding = question_embeddings[0]

        # Apply HyDE query expansion if available (RPi 4 optimization)
        hyde_results = []
        try:
            hyde_expansion = await hyde_expander.expand_query(question, ollama_manager, embed_model, question_embedding)

            if hyde_expansion.get("expanded"):
                logger.info("🔄 Using HyDE query expansion")
                # Search with hypothetical embedding
                for kb_id in pipeline["knowledge_base_ids"]:
                    try:
                        hyde_search = client.query_points(
                            collection_name=kb_id, query=hyde_expansion["hypothetical_embedding"], limit=top_k
                        )
                        hyde_results.extend(hyde_search.points)
                    except Exception as e:
                        logger.warning(f"⚠️ HyDE search failed for KB {kb_id}: {e}")
        except Exception as e:
            logger.warning(f"⚠️ HyDE expansion failed: {e}")

        # Search across all knowledge bases with hybrid search if available
        all_results = []
        for kb_id in pipeline["knowledge_base_ids"]:
            try:
                search_result = client.query_points(collection_name=kb_id, query=question_embedding, limit=top_k * 2)

                # Try hybrid search if index available
                if kb_id in hybrid_searcher.sparse_index:
                    hybrid_results = await hybrid_searcher.hybrid_search(kb_id, question_embedding, question, search_result.points, top_k)
                    # Convert hybrid results back to point objects
                    for doc_id, hybrid_score in hybrid_results:
                        # Find corresponding point
                        for point in search_result.points:
                            if point.id == doc_id or point.payload.get("_id") == doc_id:
                                point.score = hybrid_score  # Update score with hybrid score
                                all_results.append(point)
                                break
                else:
                    # Pure semantic search fallback
                    all_results.extend(search_result.points)

            except Exception as e:
                logger.warning(f"⚠️  Search failed for KB {kb_id}: {e}")

        # Combine original results with HyDE results if available (RPi 4 optimization)
        if hyde_results:
            logger.info(f"🔄 Combining {len(hyde_results)} HyDE results with {len(all_results)} original results")
            # Add HyDE results with slight score boost to prioritize them
            for hyde_point in hyde_results:
                hyde_point.score = hyde_point.score * 1.1  # 10% boost for HyDE results
                all_results.append(hyde_point)

        # Sort by score and take top_k * 2 for re-ranking
        all_results = sorted(all_results, key=lambda x: x.score, reverse=True)[: top_k * 2]

        # Apply cross-encoder re-ranking if available (RPi 4 optimization)
        try:
            documents_for_rerank = [{"text": r.payload.get("text", ""), "score": r.score} for r in all_results]
            reranked_docs = reranker.rerank(question, documents_for_rerank, top_k)

            # Reconstruct results with re-ranked scores
            reranked_results = []
            for doc, score in reranked_docs:
                # Find corresponding point
                for point in all_results:
                    if point.payload.get("text") == doc.get("text"):
                        point.score = score
                        reranked_results.append(point)
                        break

            all_results = reranked_results[:top_k]
            logger.info(f"✅ Re-ranking applied: {len(all_results)} results")
        except Exception as e:
            logger.warning(f"⚠️ Re-ranking failed, using original scores: {e}")
            # Fallback to original top_k
            all_results = all_results[:top_k]

        # Apply CRAG (Corrective RAG) fallback if retrieval quality is poor
        try:
            # Convert points to dict format for CRAG evaluation
            internal_results = [
                {"id": str(r.id), "text": r.payload.get("text", ""), "score": r.score} for r in all_results
            ]

            # Apply CRAG fallback
            crag_result = await crag_retriever.retrieve_with_fallback(
                query=question,
                internal_results=internal_results,
                kb_id=pipeline["knowledge_base_ids"][0],
                max_results=top_k
            )

            if crag_result.get("fallback_used"):
                logger.info(f"🌐 CRAG fallback applied: {crag_result['web_count']} web results added")

                # Convert CRAG results back to point format
                # (Note: This is a simplified conversion, in production you'd want more sophisticated handling)
                all_results = []
                for i, result in enumerate(crag_result.get("results", [])):
                    # Create a point-like structure
                    point_dict = {
                        "id": result.get("id", f"web_{i}"),
                        "text": result.get("text", ""),
                        "source": result.get("source", "web_search"),
                        "score": result.get("score", 0.7)
                    }
                    all_results.append(point_dict)

                logger.info(f"✅ CRAG enhanced retrieval: {len(all_results)} total results")
        except Exception as e:
            logger.warning(f"⚠️ CRAG fallback failed: {e}")
            # Continue with internal results

        # Apply parent-child retrieval enhancement if available (RPi 4 optimization)
        try:
            first_kb_id = pipeline["knowledge_base_ids"][0]
            if knowledge_bases[first_kb_id].get("parent_child_enabled", False):
                # Convert points to dict format for parent-child retriever
                child_results = [
                    {"id": str(r.id), "text": r.payload.get("text", ""), "source": r.payload.get("source", ""), "score": r.score}
                    for r in all_results
                ]
                enhanced_results = parent_child_retriever.retrieve_with_parent_context(first_kb_id, child_results)

                # Convert back to point format (simplified)
                context_sources = enhanced_results
                logger.info(f"✅ Parent-child retrieval applied: {len(enhanced_results)} results")
            else:
                # Regular context extraction
                context_sources = [
                    {"text": r.payload.get("text", ""), "source": r.payload.get("source", ""), "score": r.score} for r in all_results
                ]
        except Exception as e:
            logger.warning(f"⚠️ Parent-child retrieval failed: {e}")
            # Fallback to regular context extraction
            context_sources = [{"text": r.payload.get("text", ""), "source": r.payload.get("source", ""), "score": r.score} for r in all_results]

        # Extract context
        context_sources = [{"text": r.payload.get("text", ""), "source": r.payload.get("source", ""), "score": r.score} for r in all_results]

        # Apply contextual compression (RPi 4 optimization)
        try:
            compression_result = context_compressor.compress(question, context_sources)
            compressed_context = compression_result["compressed_context"]
            compression_ratio = compression_result.get("compressed_length", 0) / max(compression_result.get("original_length", 1), 1)

            logger.info(f"✅ Context compressed: {compression_ratio:.1%} ratio")
        except Exception as e:
            logger.warning(f"⚠️ Context compression failed: {e}")
            compressed_context = "\n\n".join([ctx.get("text", "") for ctx in context_sources])

        return {
            "context": compressed_context,
            "sources": context_sources,
        }


