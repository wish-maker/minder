@app.post("/raptor/upload", response_model=RAPTORUploadResponse, tags=["RAPTOR RAG"])
async def upload_raptor_document(kb_id: str, file: UploadFile = File(...)):
    """
    Upload document and create RAPTOR tree structure

    Creates hierarchical tree by:
    1. Chunking document
    2. Clustering similar chunks
    3. Summarizing each cluster
    4. Building tree structure recursively
    """
    if kb_id not in knowledge_bases:
        raise HTTPException(status_code=404, detail="Knowledge base not found")

    try:
        # Read file
        content = await file.read()

        # Extract text
        text = await extract_text_from_file(content, file.filename)

        if not text or len(text) < 100:
            raise HTTPException(status_code=400, detail="Document too short for RAPTOR processing")

        # Generate embeddings for base chunks
        kb = knowledge_bases[kb_id]
        base_chunks = chunk_text(text, chunk_size=kb["chunk_size"], chunk_overlap=kb["chunk_overlap"])

        if len(base_chunks) < 3:
            raise HTTPException(status_code=400, detail="Document too short for RAPTOR (minimum 3 chunks required)")

        logger.info(f"📄 Processing {file.filename} with RAPTOR: {len(base_chunks)} base chunks")

        # Generate embeddings
        embeddings = await ollama_manager.generate_embeddings(base_chunks, model=kb["embedding_model"])

        # Create RAPTOR tree structure
        tree_result = raptor_chunker.create_tree_structure(
            text=text,
            llm_manager=ollama_manager,
            embeddings=embeddings,
            embedding_model=kb["embedding_model"]
        )

        # Index tree for retrieval
        raptor_retriever.index_tree(kb_id, tree_result["tree"])

        # Store tree metadata in KB
        kb["raptor_enabled"] = True
        kb["raptor_tree_info"] = tree_result["metadata"]

        logger.info(f"✅ RAPTOR tree created: {tree_result['metadata']}")

        return RAPTORUploadResponse(
            message="RAPTOR tree created successfully",
            filename=file.filename,
            tree_info=RAPTORTreeInfo(**tree_result["metadata"])
        )

    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ RAPTOR upload failed: {e}")
        raise HTTPException(status_code=500, detail=f"RAPTOR processing failed: {str(e)}")


@app.post("/raptor/query", response_model=QueryResponse, tags=["RAPTOR RAG"])
async def query_raptor(request: RAPTORQueryRequest):
    """
    Query using RAPTOR retrieval

    Automatically selects appropriate tree level:
    - Specific queries → leaf nodes (detailed chunks)
    - General queries → cluster nodes (summaries)
    """
    if request.kb_id not in knowledge_bases:
        raise HTTPException(status_code=404, detail="Knowledge base not found")

    kb = knowledge_bases[request.kb_id]

    if not kb.get("raptor_enabled"):
        raise HTTPException(status_code=400, detail="RAPTOR not enabled for this knowledge base")

    try:
        # Generate query embedding
        question_embeddings = await ollama_manager.generate_embeddings(
            [request.question],
            model=kb["embedding_model"]
        )
        question_embedding = question_embeddings[0]

        # Retrieve from RAPTOR tree
        raptor_results = raptor_retriever.retrieve_from_tree(
            kb_id=request.kb_id,
            query=request.question,
            query_embedding=question_embedding,
            top_k=request.top_k,
            llm_manager=ollama_manager
        )

        if not raptor_results:
            # Fallback to regular retrieval
            logger.warning("⚠️ RAPTOR retrieval returned no results, falling back to standard retrieval")
            # Would call standard retrieval here
            raptor_results = []

        # Build context from RAPTOR results
        context_parts = []
        sources = []

        for result in raptor_results:
            context_parts.append(result.get("text", ""))
            sources.append({
                "text": result.get("text", ""),
                "score": result.get("score", 0.0),
                "node_type": result.get("node_type", "unknown"),
                "level": result.get("level", 0)
            })

        context = "\n\n".join(context_parts)

        # Generate answer
        llm_result = await ollama_manager.generate_response(
            prompt=request.question,
            context=context,
            model=kb["llm_model"]
        )

        # Calculate confidence
        if sources:
            avg_score = sum(s["score"] for s in sources) / len(sources)
            confidence = min(0.95, 0.5 + avg_score * 0.45)
        else:
            confidence = 0.5

        logger.info(f"✅ RAPTOR query completed: {len(sources)} nodes retrieved")

        return QueryResponse(
            answer=llm_result["text"],
            sources=sources,
            confidence=confidence,
            model_used=kb["llm_model"],
            tokens_used=llm_result.get("tokens_used")
        )

    except Exception as e:
        logger.error(f"❌ RAPTOR query failed: {e}")
        raise HTTPException(status_code=500, detail=f"RAPTOR query failed: {str(e)}")


