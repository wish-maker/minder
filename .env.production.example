# Minder Environment Variables
# Version: 1.0.0
#
# This file contains SECRETS ONLY.
# All other configuration is in config.yaml.
#
# Usage: Copy this file to .env and fill in your values.

# ============================================================================
# CRITICAL SECRETS (REQUIRED)
# ============================================================================

# PostgreSQL Database Password
# Generate with: openssl rand -base64 24
POSTGRES_PASSWORD=your_secure_postgres_password_here_min_16_chars

# JWT Secret Key
# Generate with: openssl rand -hex 32
# Minimum 32 characters required
JWT_SECRET_KEY=your_jwt_secret_key_here_must_be_at_least_32_characters_long

# ============================================================================
# OPTIONAL SECRETS
# ============================================================================

# InfluxDB Password (if not using default)
INFLUXDB_PASSWORD=minder123

# Redis Password (if Redis requires authentication)
# REDIS_PASSWORD=

# GitHub Personal Access Token (for plugin store - optional)
# Generate at: https://github.com/settings/personal-access-tokens
# GITHUB_TOKEN=

# ============================================================================
# DATABASE CONNECTION (OPTIONAL)
# ============================================================================

# Database Host (default: postgres)
# POSTGRES_HOST=postgres

# Database Port (default: 5432)
# POSTGRES_PORT=5432

# Database User (default: postgres)
# POSTGRES_USER=postgres

# ============================================================================
# NETWORK CONFIGURATION (OPTIONAL)
# ============================================================================

# Redis Host (default: localhost)
# REDIS_HOST=localhost

# Redis Port (default: 6379)
# REDIS_PORT=6379

# ============================================================================
# SECURITY CONFIGURATION (OPTIONAL)
# ============================================================================

# Environment (development, production)
# ENVIRONMENT=production

# Plugin Security Level (low, moderate, high)
# PLUGIN_SECURITY_LEVEL=moderate

# Local Network CIDR (for rate limiting)
# LOCAL_NETWORK_CIDR=192.168.68.0/24

# Tailscale CIDR (for VPN detection)
# TAILSCALE_CIDR=100.64.0.0/10

# Allowed Origins for CORS (comma-separated)
# ALLOWED_ORIGINS=http://localhost:3000,http://192.168.68.*,http://100.*.*.*

# ============================================================================
# MONITORING (OPTIONAL)
# ============================================================================

# Grafana Admin Password
# GRAFANA_ADMIN_PASSWORD=minder123

# ============================================================================
# NOTES
# ============================================================================
#
# 1. Never commit .env file to version control
# 2. Use strong, unique passwords in production
# 3. Rotate secrets regularly (recommended: every 90 days)
# 4. Keep backup of secrets in secure location
# 5. Use different passwords for different environments
#
# ============================================================================
