{
  "format_version": "2.0",
  "id": "weather",
  "name": "Weather Plugin",
  "version": "1.0.0",
  "description": "Weather data collection and correlation analysis",
  "author": "FundMind AI <dev@fundmind.ai>",
  "categories": ["data-collection", "weather"],
  "tags": ["weather", "forecast", "climate", "seasonal"],
  "compatibility": {
    "minder_core": ">=2.0.0"
  },
  "github": {
    "repo": "https://github.com/minder-plugins/weather.git",
    "branch": "main",
    "tag": "v1.0.0",
    "auto_update": false,
    "release_channel": "stable"
  },
  "dependencies": {
    "plugins": [],
    "services": {
      "postgres": {
        "required": true,
        "version": ">=14.0",
        "namespace": "plugin:weather:*",
        "auto_create": true
      }
    },
    "python_packages": [
      "requests>=2.31.0",
      "python-dateutil>=2.8.0"
    ]
  },
  "core_api": {
    "type": "http",
    "port": 8010,
    "protocol": "http",
    "endpoints": {
      "health": {
        "path": "/health",
        "method": "GET",
        "auth_required": false
      },
      "install": {
        "path": "/core/install",
        "method": "POST",
        "auth_required": true
      },
      "uninstall": {
        "path": "/core/uninstall",
        "method": "POST",
        "auth_required": true
      },
      "configure": {
        "path": "/core/configure",
        "method": "POST",
        "auth_required": true
      },
      "status": {
        "path": "/core/status",
        "method": "GET",
        "auth_required": false
      }
    }
  },
  "permissions": {
    "apis": [
      {
        "name": "openweathermap",
        "url": "https://api.openweathermap.org",
        "auth_required": true,
        "rate_limit": 60
      }
    ],
    "file_system": {
      "read": ["/data/weather", "/tmp/weather"],
      "write": ["/data/weather/output", "/var/log/minder/weather"],
      "deny": ["/etc", "/sys", "/proc", "/root"]
    },
    "network": {
      "allow": ["api.openweathermap.org:443", "*.openweathermap.org:443"],
      "deny": ["*"]
    }
  },
  "resources": {
    "cpu": {
      "limit": "0.3",
      "reservation": "0.1"
    },
    "memory": {
      "limit": "256MB",
      "reservation": "64MB"
    },
    "storage": {
      "database": "500MB",
      "files": "200MB"
    },
    "threads": {
      "max": 2,
      "min": 1
    }
  },
  "secrets": {
    "required": ["OPENWEATHER_API_KEY"],
    "optional": ["WEATHER_API_BACKUP_KEY"]
  },
  "configuration": {
    "schema": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "update_interval_seconds": {
          "type": "integer",
          "default": 1800,
          "minimum": 300,
          "maximum": 86400
        },
        "default_location": {
          "type": "string",
          "default": "Istanbul,TR"
        },
        "forecast_days": {
          "type": "integer",
          "default": 5,
          "minimum": 1,
          "maximum": 16
        }
      }
    },
    "ui": {
      "title": "Weather Plugin Configuration",
      "icon": "🌤️",
      "category": "Data Collection"
    }
  },
  "sandbox": {
    "enabled": true,
    "type": "process",
    "isolation": {
      "namespace": "weather_plugin",
      "network": "restricted",
      "file_system": "chroot"
    },
    "limits": {
      "max_execution_time": 120,
      "max_memory": "256MB",
      "max_files": 100
    }
  },
  "monitoring": {
    "metrics_path": "/metrics",
    "health_path": "/health",
    "log_path": "/var/log/minder/weather.log"
  },
  "scripts": {
    "install": "/scripts/install.sh",
    "uninstall": "/scripts/uninstall.sh"
  },
  "testing": {
    "unit_tests": "/tests/unit",
    "integration_tests": "/tests/integration"
  },
  "changelog": [
    {
      "version": "1.0.0",
      "date": "2026-04-20",
      "changes": [
        "Initial release with JSON manifest",
        "Basic weather data collection",
        "Forecast analysis capabilities"
      ]
    }
  ]
}
