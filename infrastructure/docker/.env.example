# Minder Platform - Environment Configuration Template
# IMPORTANT: Copy this file to .env and fill in with STRONG, UNIQUE values
# DO NOT use default values in production!

# ============================================================================
# ⚠️  SECURITY CHECKLIST - Complete before deploying to production
# ============================================================================
# [ ] Generate unique passwords using: ./scripts/generate-secrets.sh
# [ ] Generate JWT_SECRET using: openssl rand -base64 64
# [ ] Generate AUTHELIA_JWT_SECRET using: openssl rand -base64 32
# [ ] Generate AUTHELIA_SESSION_SECRET using: openssl rand -base64 32
# [ ] Generate AUTHELIA_STORAGE_ENCRYPTION_KEY using: openssl rand -base64 32
# [ ] Set ENVIRONMENT=production
# [ ] Review plugin security settings
# [ ] Configure SSL/TLS certificates
# [ ] Set up firewall rules
# [ ] Review backup retention policy
# [ ] NEVER commit this .env file to version control
# ============================================================================

# =============================================================================
# PILLAR 1: Zero-Trust Security Configuration
# =============================================================================

# IP Whitelist for Traefik (LAN/VPN subnets only - comma separated CIDR)
# Example: 192.168.1.0/24 for home LAN, 10.8.0.0/24 for VPN
TRAEFIK_TRUSTED_IPS=192.168.1.0/24,10.8.0.0/24

# =============================================================================
# Database Credentials
# =============================================================================
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_HERE

# =============================================================================
# Redis Credentials
# =============================================================================
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_HERE

# =============================================================================
# RabbitMQ Credentials
# =============================================================================
# Generate with: openssl rand -base64 32
RABBITMQ_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_HERE

# =============================================================================
# MinIO Object Storage Configuration
# =============================================================================
# MinIO provides S3-compatible object storage for documents, models, and artifacts

# MinIO root user credentials
# Generate with: openssl rand -base64 32
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_HERE

# MinIO console access (via Traefik: https://minio.minder.local)
MINIO_CONSOLE_PORT=9001

# MinIO API endpoint (internal services use this)
MINIO_API_ENDPOINT=http://minio:9000

# MinIO bucket names (auto-created during setup)
MINIO_BUCKET_RAG_DOCUMENTS=rag-documents
MINIO_BUCKET_TTS_ARTIFACTS=tts-artifacts
MINIO_BUCKET_FINETUNING_DATASETS=fine-tuning-datasets
MINIO_BUCKET_MODEL_CHECKPOINTS=model-checkpoints
MINIO_BUCKET_PLUGIN_PACKAGES=plugin-packages
MINIO_BUCKET_BACKUP_ARCHIVES=backup-archives

# MinIO region (for S3 SDK compatibility)
MINIO_REGION=us-east-1

# =============================================================================
# Schema Registry Configuration
# =============================================================================
# Schema Registry service address (internal)
SCHEMA_REGISTRY_HOST=schema-registry:8081

# Schema Registry public URL (external access)
SCHEMA_REGISTRY_URL=http://localhost:8082

# =============================================================================
# JWT Authentication
# =============================================================================
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_JWT_SECRET_HERE

# JWT expiration time (minutes)
JWT_EXPIRATION_MINUTES=60

# Rate limiting configuration
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=100

# =============================================================================
# PILLAR 4: Deep Observability Configuration
# =============================================================================

# InfluxDB Configuration
# Generate with: openssl rand -base64 32
INFLUXDB_TOKEN=CHANGE_ME_GENERATE_STRONG_TOKEN_HERE
INFLUXDB_ADMIN_USERNAME=admin
INFLUXDB_ADMIN_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_HERE

# Grafana Configuration
GRAFANA_ADMIN_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_HERE

# =============================================================================
# Application Settings
# =============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# =============================================================================
# Ollama Configuration
# =============================================================================
# Automatic model download on startup (true/false)
OLLAMA_AUTOMATIC_PULL=true

# Models to download automatically (comma-separated)
# Available models: llama3.2, mistral, qwen2.5, nomic-embed-text, mxbai-embed-large
OLLAMA_MODELS=llama3.2,nomic-embed-text

# Embedding model for RAG pipeline
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# LLM model for general queries
OLLAMA_LLM_MODEL=llama3.2

# =============================================================================
# PILLAR 2: AI Endpoint Configuration (Hybrid AI Endpoints)
# =============================================================================
# Primary endpoint strategy: local, lan, or cloud
# - local: Use local Docker Ollama (minder-ollama:11434)
# - lan: Use LAN network Ollama (e.g., 192.168.1.100:11434)
# - cloud: Use cloud API (e.g., OpenAI, vLLM endpoint)
AI_ENDPOINT_STRATEGY=local

# Local Docker Ollama endpoint (default)
AI_LOCAL_OLLAMA_URL=http://minder-ollama:11434

# LAN network Ollama endpoint (optional, for strategy=lan)
# Example: AI_LAN_OLLAMA_URL=http://192.168.1.100:11434
AI_LAN_OLLAMA_URL=

# Cloud API endpoint (optional, for strategy=cloud)
# Example: AI_CLOUD_API_URL=https://api.openai.com/v1
AI_CLOUD_API_URL=

# Enable automatic fallback to alternative endpoints
AI_ENABLE_FALLBACK=true

# Timeout for endpoint health checks (milliseconds)
AI_FALLBACK_TIMEOUT_MS=5000

# Default model for inference
AI_DEFAULT_MODEL=llama3.2

# Model for embedding generation
AI_EMBEDDING_MODEL=nomic-embed-text

# =============================================================================
# Authelia - Single Sign-On & 2FA (Pillar 1)
# =============================================================================
# Generate with: openssl rand -base64 32
AUTHELIA_JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_HERE
AUTHELIA_SESSION_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET_HERE
AUTHELIA_STORAGE_ENCRYPTION_KEY=CHANGE_ME_GENERATE_STRONG_KEY_HERE

# Authelia Redirection
AUTHELIA_DEFAULT_REDIRECTION_URL=https://public.minder.local

# =============================================================================
# OIDC / OAuth2 Configuration
# =============================================================================
# Generate with: openssl rand -base64 32
OIDC_CLIENT_SECRET_MINDER_WEB=CHANGE_ME_GENERATE_STRONG_SECRET_HERE
OIDC_CLIENT_SECRET_MINDER_API=CHANGE_ME_GENERATE_STRONG_SECRET_HERE

# =============================================================================
# SMTP Configuration (for Authelia notifications)
# =============================================================================
# Example for Gmail (use App Passwords):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME_YOUR_EMAIL
SMTP_PASSWORD=CHANGE_ME_YOUR_APP_PASSWORD

# =============================================================================
# Traefik / SSL Configuration
# =============================================================================
# ACME Email for Let's Encrypt certificates
ACME_EMAIL=admin@minder.local

# =============================================================================
# Model Fine Tuning Configuration
# =============================================================================
DEFAULT_BASE_MODEL=llama3.2

# =============================================================================
# PHASE 3: GPU Passthrough Configuration
# =============================================================================
# NVIDIA GPU configuration for AI service acceleration

# GPU visibility and allocation
CUDA_VISIBLE_DEVICES=all
GPU_MEMORY_UTILIZATION=0.9
GPU_DEVICE_COUNT=all

# GPU compute preferences
GPU_COMPUTE_MODE=cuda  # Options: cpu, cuda, mps (Multi-Process Server)
GPU_MEMORY_FRACTION=0.9  # Fraction of GPU memory to use per process

# =============================================================================
# Model Fine Tuning Configuration
# =============================================================================
DEFAULT_BASE_MODEL=llama3.2

# =============================================================================
# TTS/STT Service Configuration
# =============================================================================
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
STT_MODEL=base
TTS_DEVICE=cuda  # Changed to cuda for GPU acceleration (was: cpu)
TTS_COMPUTE_TYPE=float16  # Changed to float16 for better GPU performance (was: int8)

# =============================================================================
# OpenWebUI Configuration
# =============================================================================
WEBUI_SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET_HERE
WEBUI_AUTH=true

# =============================================================================
# Neo4j Configuration
# =============================================================================
NEO4J_AUTH=neo4j/CHANGE_ME_NEO4J_PASSWORD_HERE

# =============================================================================
# Enterprise Configuration (Dynamic Modes)
# =============================================================================
# Access Mode - Controls how services are accessed and secured
# Options: local, vpn, public
# local:   Services accessible only on localhost (development)
# vpn:     Services accessible via VPN with enhanced security
# public:  Services accessible via internet with DDoS protection
ACCESS_MODE=local

# AI Compute Mode - Controls AI/ML processing and resource allocation
# Options: internal, external, hybrid
# internal: Use local Ollama with GPU acceleration
# external: Route AI requests to external GPU node ($EXTERNAL_GPU_NODE_URL)
# hybrid:    Use local Ollama with external GPU fallback
AI_COMPUTE_MODE=internal

# External GPU Node URL (required when AI_COMPUTE_MODE=external or hybrid)
# Example: http://gpu-node.example.com:11434
EXTERNAL_GPU_NODE_URL=

# Compute Resource Profile - Controls resource allocation and limits
# Options: low, medium, high, enterprise
# low:       2GB RAM, 1 CPU core (development)
# medium:    4GB RAM, 2 CPU cores (staging)
# high:       8GB RAM, 4 CPU cores (production)
# enterprise: 16GB RAM, 8 CPU cores with GPU passthrough
COMPUTE_RESOURCE_PROFILE=medium

# Enterprise Features Toggle
ENTERPRISE_FEATURES=false
COMPLIANCE_MODE=false
AUDIT_LOGGING_ENABLED=false
MULTI_TENANCY_ENABLED=false

# =============================================================================
# PHASE 2: Distributed Tracing Configuration
# =============================================================================
# Jaeger tracing platform for distributed system observability

# Jaeger storage backend (memory, elasticsearch, cassandra)
JAEGER_STORAGE_TYPE=memory

# OpenTelemetry Collector Configuration
OTEL_COLLECTOR_ENDPOINT=otel-collector:4317
OTEL_EXPORTER_OTLP_ENDPOINT=jaeger:14250
OTEL_EXPORTER_OTLP_PROTOCOL=grpc

# Trace sampling rate (1.0 = 100%, 0.1 = 10%)
OTEL_TRACE_SAMPLING_RATIO=1.0

# =============================================================================
# Security Notes
# =============================================================================
# PASSWORD REQUIREMENTS:
# - Minimum 32 characters
# - Mix of uppercase, lowercase, numbers, and symbols
# - Unique per environment (dev/staging/prod)
# - Rotated quarterly
#
# JWT SECRET REQUIREMENTS:
# - Minimum 64 characters
# - Cryptographically random
# - Never commit to git
# - Rotate immediately if suspected compromise
#
# GENERATION COMMANDS:
# postgres/redis: openssl rand -base64 32
# jwt secret:     openssl rand -base64 64
# influxdb token: openssl rand -base64 32
