# Minder Platform - Environment Configuration Template
# IMPORTANT: Copy this file to .env and fill in with STRONG, UNIQUE values
# DO NOT use default values in production!

# =============================================================================
# Database Credentials
# =============================================================================
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_HERE

# =============================================================================
# Redis Credentials
# =============================================================================
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD_HERE

# =============================================================================
# JWT Authentication
# =============================================================================
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_JWT_SECRET_HERE

# =============================================================================
# InfluxDB Configuration
# =============================================================================
# Generate with: openssl rand -base64 32
INFLUXDB_TOKEN=CHANGE_ME_GENERATE_STRONG_TOKEN_HERE

# =============================================================================
# Application Settings
# =============================================================================
ENVIRONMENT=production
LOG_LEVEL=INFO

# =============================================================================
# Security Notes
# =============================================================================
# PASSWORD REQUIREMENTS:
# - Minimum 32 characters
# - Mix of uppercase, lowercase, numbers, and symbols
# - Unique per environment (dev/staging/prod)
# - Rotated quarterly
#
# JWT SECRET REQUIREMENTS:
# - Minimum 64 characters
# - Cryptographically random
# - Never commit to git
# - Rotate immediately if suspected compromise
#
# GENERATION COMMANDS:
# postgres/redis: openssl rand -base64 32
# jwt secret:     openssl rand -base64 64
# influxdb token: openssl rand -base64 32
