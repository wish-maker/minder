{
  "dashboard": {
    "title": "Minder Platform - System Metrics",
    "tags": ["minder", "influxdb", "monitoring"],
    "timezone": "browser",
    "panels": [
      {
        "id": 1,
        "title": "CPU Usage (%)",
        "type": "timeseries",
    "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
        "targets": [
          {
            "query": "from(bucket: \"minder-metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_metrics\")\n  |> filter(fn: (r) => r.metric_name == \"cpu_usage_percent\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 70, "color": "yellow"},
                {"value": 90, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Memory Usage (%)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
        "targets": [
          {
            "query": "from(bucket: \"minder-metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_metrics\")\n  |> filter(fn: (r) => r.metric_name == \"memory_usage_percent\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"mean\")",
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 80, "color": "yellow"},
                {"value": 95, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Network Traffic (bytes/sec)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
        "targets": [
          {
            "query": "from(bucket: \"minder-metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_metrics\")\n  |> filter(fn: (r) => r.metric_name == \"network_bytes_sent\" or r.metric_name == \"network_bytes_recv\")\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"traffic\")",
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "Bps",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Load Average",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
        "targets": [
          {
            "query": "from(bucket: \"minder-metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_metrics\")\n  |> filter(fn: (r) => r.metric_name =~ /load_average/)\n  |> aggregateWindow(every: v.windowPeriod, fn: mean, createEmpty: false)\n  |> yield(name: \"load\")",
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Disk Usage (%)",
        "type": "gauge",
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 16},
        "targets": [
          {
            "query": "from(bucket: \"minder-metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_metrics\")\n  |> filter(fn: (r) => r.metric_name == \"disk_usage_percent\")\n  |> last()\n  |> yield(name: \"disk\")",
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "green"},
                {"value": 70, "color": "yellow"},
                {"value": 90, "color": "red"}
              ]
            }
          }
        }
      },
      {
        "id": 6,
        "title": "Available Memory (GB)",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 16},
        "targets": [
          {
            "query": "from(bucket: \"minder-metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_metrics\")\n  |> filter(fn: (r) => r.metric_name == \"memory_available_gb\")\n  |> last()\n  |> yield(name: \"memory\")",
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "decimals": 2,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"value": 0, "color": "red"},
                {"value": 2000000000, "color": "yellow"},
                {"value": 4000000000, "color": "green"}
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "System Metrics Summary",
        "type": "stat",
        "gridPos": {"h": 6, "w": 12, "x": 12, "y": 16},
        "targets": [
          {
            "query": "from(bucket: \"minder-metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_metrics\")\n  |> group()\n  |> count()\n  |> yield(name: \"total_metrics\")",
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "decimals": 0,
            "color": {"mode": "value"}
          }
        },
        "options": {
          "graphMode": "none",
          "colorMode": "value",
          "textMode": "auto"
        }
      },
      {
        "id": 8,
        "title": "Metrics Collection Rate",
        "type": "timeseries",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 22},
        "targets": [
          {
            "query": "from(bucket: \"minder-metrics\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"network_metrics\")\n  |> group(columns: [\"_measurement\"])\n  |> aggregateWindow(every: 1m, fn: count, createEmpty: false)\n  |> yield(name: \"metrics_per_minute\")",
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20
            }
          }
        }
      }
    ],
    "refresh": "10s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    }
  }
}
