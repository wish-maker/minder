# ─────────────────────────────────────────────────────────────
# TRAP — cleanup on unexpected exit
# ─────────────────────────────────────────────────────────────

_cleanup() {
    local exit_code=$?
    spinner_stop
    if (( exit_code != 0 )); then
        echo -e "\n${RED}✗ Script exited unexpectedly (code ${exit_code})${NC}"
        echo -e "${DIM}Full log: ${LOG_FILE}${NC}"
    fi
}
